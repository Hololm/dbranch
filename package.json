{
  "name": "dbranch",
  "version": "0.1.2",
  "description": "Git-style branching for local development databases",
  "type": "module",
  "bin": {
    "dbranch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "database",
    "git",
    "branch",
    "snapshot",
    "sqlite",
    "postgres",
    "cli"
  ],
  "author": "Hololm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hololm/dbranch.git"
  },
  "homepage": "https://github.com/Hololm/dbranch#readme",
  "bugs": {
    "url": "https://github.com/Hololm/dbranch/issues"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "execa": "^9.5.2",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.20.0",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
